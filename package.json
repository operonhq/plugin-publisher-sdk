{
  "name": "@operon/plugin-publisher-sdk",
  "version": "0.1.4",
  "description": "ElizaOS plugin for Operon - monetize agent responses with quality-weighted sponsored placements",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test src/client.test.ts src/providers/operonPlacement.test.ts src/providers/operonPlacement.integration.test.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@elizaos/core": "^0.1.0"
  },
  "devDependencies": {
    "@elizaos/core": "^0.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "OPERON_URL": {
        "type": "string",
        "required": true,
        "description": "Operon network URL (e.g. https://api.operon.so)"
      },
      "OPERON_API_KEY": {
        "type": "string",
        "required": true,
        "description": "Publisher API key from Operon"
      },
      "OPERON_PUBLISHER_NAME": {
        "type": "string",
        "required": false,
        "description": "Publisher identifier reported to Operon (defaults to character name)"
      },
      "OPERON_DEFAULT_CATEGORY": {
        "type": "string",
        "required": false,
        "description": "Default category for placement requests (e.g. defi, gaming, social)"
      },
      "OPERON_DEFAULT_INTENT": {
        "type": "string",
        "required": false,
        "description": "Default intent for placement requests (e.g. research, swap, trade)"
      }
    }
  },
  "keywords": [
    "elizaos",
    "plugin",
    "ai-agents",
    "ad-network",
    "operon",
    "monetization"
  ],
  "author": "Operon (https://operon.so)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/operonhq/plugin-publisher-sdk"
  },
  "homepage": "https://operon.so"
}
